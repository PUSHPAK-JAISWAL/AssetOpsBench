# ── CouchDB (IoTAgent server) ────────────────────────────────────────────────
COUCHDB_URL=http://localhost:5984
COUCHDB_USERNAME=admin
COUCHDB_PASSWORD=password
IOT_DBNAME=chiller                                                             
WO_DBNAME=workorder

# ── IBM WatsonX (plan-execute runner) ────────────────────────────────────────
WATSONX_APIKEY=
WATSONX_PROJECT_ID=
WATSONX_URL=https://us-south.ml.cloud.ibm.com   # optional

# ── LiteLLM (plan-execute runner) ────────────────────────────────────────────
LITELLM_API_KEY=
LITELLM_BASE_URL=

# ── Anthropic / Claude Agent SDK ─────────────────────────────────────────────
ANTHROPIC_API_KEY=                               # Anthropic key, or LiteLLM key when using a proxy
ANTHROPIC_BASE_URL=                              # optional: LiteLLM proxy URL, e.g. http://localhost:4000
